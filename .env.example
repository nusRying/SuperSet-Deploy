SUPERSET_VERSION=latest
POSTGRES_VERSION=16-alpine
SECRETS_VERSION=latest
SUPERSET_PIP_PACKAGES=psycopg2-binary redis gevent openpyxl
POSTGRES_SYNC_PASSWORD=true
# Optional advanced override. Leave unset for normal Coolify deployments.
# SUPERSET_SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://superset:password@db:5432/superset
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
POSTGRES_DB=superset
POSTGRES_USER=superset
PREFERRED_URL_SCHEME=https
SESSION_COOKIE_SECURE=true
SUPERSET_LOAD_EXAMPLES=no
